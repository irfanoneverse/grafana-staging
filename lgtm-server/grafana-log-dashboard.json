        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "id": 103,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "hideZeros": false,
          "mode": "multi",
          "sort": "desc"
        }
      },
      "pluginVersion": "11.5.2",
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (level) (count_over_time({job=~\"$job\", instance=~\"$instance\", level=~\".+\"}[$__interval]))",
          "legendFormat": "{{level}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Logs by Level",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "id": 104,
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "Lines"
          }
        ]
      },
      "pluginVersion": "11.5.2",
      "targets": [
        {
          "editorMode": "code",
          "expr": "topk(10, sum by (job, instance) (count_over_time({job=~\"$job\", instance=~\"$instance\"}[5m])))",
          "legendFormat": "{{job}} / {{instance}}",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Top Log Producers (5m)",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "Value": 2,
              "job": 0,
              "instance": 1
            },
            "renameByName": {
              "Value": "Lines"
            }
          }
        }
      ],
      "type": "table"
    }
  ],
