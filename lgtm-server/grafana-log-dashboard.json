          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Live Logs",
      "type": "logs"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "fieldConfig": {
