        {
          "editorMode": "code",
          "expr": "sum(count_over_time({job=~\"$job\", instance=~\"$instance\"}[$__interval]))",
          "legendFormat": "lines",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Log Volume",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "fieldConfig": {
        "defaults": {
