{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus / Mimir",
      "type": "datasource",
      "pluginId": "prometheus"
    },
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "type": "datasource",
      "pluginId": "loki"
    }
  ],
  "title": "Application Server Monitoring",
  "uid": "app-monitor-v3",
  "description": "Developer dashboard — server health, resources, disk, and application logs. Add new servers in Alloy and they appear automatically.",
  "tags": ["monitoring", "production", "laravel", "ec2"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Metrics Source",
        "type": "datasource",
        "pluginId": "prometheus",
        "query": "prometheus",
        "hide": 0,
        "includeAll": false,
        "multi": false
      },
      {
        "name": "loki_datasource",
        "label": "Logs Source",
        "type": "datasource",
        "pluginId": "loki",
        "query": "loki",
        "hide": 0,
        "includeAll": false,
        "multi": false
      },
      {
        "name": "instance",
        "label": "Server",
        "description": "Select one or more servers to monitor. Populated from node_exporter targets only.",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": { "query": "label_values(node_boot_time_seconds, instance)", "refId": "A" },
        "refresh": 2,
        "sort": 1,
        "hide": 0,
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "current": {}
      }
    ]
  },
  "panels": [

    {
      "id": 10,
      "type": "row",
      "title": "🚦  Service Health",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },

    {
      "id": 1,
      "title": "Server Status",
      "description": "UP = node_exporter is reachable. DOWN = server or agent is unreachable. One tile per server.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "max by(instance) (up{instance=~\"$instance\"})",
          "legendFormat": "{{instance}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1    }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red",   "index": 0 },
                "1": { "text": "UP",   "color": "green", "index": 1 }
              }
            },
            {
              "type": "special",
              "options": { "match": "null", "result": { "text": "NO DATA", "color": "orange" } }
            }
          ],
          "noValue": "NO DATA"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "text": { "titleSize": 16, "valueSize": 28 }
      }
    },

    {
      "id": 2,
      "title": "Server Uptime",
      "description": "Time since last reboot. Orange = rebooted < 1 day ago, Yellow = < 1 week, Green = stable.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "time() - node_boot_time_seconds{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "orange", "value": null    },
              { "color": "yellow", "value": 86400   },
              { "color": "green",  "value": 604800  }
            ]
          },
          "noValue": "N/A"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "text": { "titleSize": 14, "valueSize": 22 }
      }
    },

    {
      "id": 20,
      "type": "row",
      "title": "⚙️  CPU & Memory",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 }
    },

    {
      "id": 3,
      "title": "CPU Usage — Now",
      "description": "Current CPU % per server. Green < 60%, Yellow < 80%, Red ≥ 80%.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\", instance=~\"$instance\"}[5m])) * 100)",
          "legendFormat": "{{instance}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 60   },
              { "color": "red",    "value": 80   }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },

    {
      "id": 4,
      "title": "Memory Usage — Now",
      "description": "Current RAM usage % per server. Green < 60%, Yellow < 80%, Red ≥ 80%.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes{instance=~\"$instance\"} / node_memory_MemTotal_bytes{instance=~\"$instance\"}))",
          "legendFormat": "{{instance}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 60   },
              { "color": "red",    "value": 80   }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },

    {
      "id": 5,
      "title": "CPU Usage — Over Time",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\", instance=~\"$instance\"}[5m])) * 100)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 12,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

    {
      "id": 6,
      "title": "Memory Usage — Over Time",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes{instance=~\"$instance\"} / node_memory_MemTotal_bytes{instance=~\"$instance\"}))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 12,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

    {
      "id": 30,
      "type": "row",
      "title": "💾  Disk Storage",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 }
    },

    {
      "id": 7,
      "title": "Disk Used % (Root Volume)",
      "description": "How full the main disk (/) is on each server. Red ≥ 85% — start cleaning up or expanding the volume.",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "100 - (node_filesystem_avail_bytes{mountpoint=\"/\", fstype!=\"tmpfs\", instance=~\"$instance\"} / node_filesystem_size_bytes{mountpoint=\"/\", fstype!=\"tmpfs\", instance=~\"$instance\"} * 100)",
          "legendFormat": "{{instance}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 70   },
              { "color": "orange", "value": 80   },
              { "color": "red",    "value": 85   }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "orientation": "horizontal",
        "displayMode": "lcd",
        "showUnfilled": true,
        "minVizHeight": 16
      }
    },

    {
      "id": 8,
      "title": "Disk Free Space (Root Volume)",
      "description": "Absolute free space remaining on the main disk of each server.",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "node_filesystem_avail_bytes{mountpoint=\"/\", fstype!=\"tmpfs\", instance=~\"$instance\"}",
          "legendFormat": "{{instance}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null         },
              { "color": "orange", "value": 2147483648   },
              { "color": "yellow", "value": 5368709120   },
              { "color": "green",  "value": 10737418240  }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "text": { "titleSize": 14, "valueSize": 22 }
      }
    },

    {
      "id": 50,
      "type": "row",
      "title": "📋  System & Application Logs & Errors",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 }
    },

    {
      "id": 12,
      "title": "Application Errors — Last 1 Hour",
      "description": "Count of ERROR and CRITICAL log lines in the last hour per server. 0 is perfect.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 30 },
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "targets": [
        {
          "expr": "sum by(instance) (count_over_time({instance=~\"$instance\"} |~ \"(?i)(error|critical|exception|failed)\" [1h]))",
          "legendFormat": "{{instance}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1    },
              { "color": "orange", "value": 10   },
              { "color": "red",    "value": 50   }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "text": { "titleSize": 14, "valueSize": 32 }
      }
    },

    {
      "id": 13,
      "title": "Error Rate Over Time",
      "description": "Rate of ERROR/CRITICAL log lines per 5-minute window. Spikes indicate application issues.",
      "type": "timeseries",
      "gridPos": { "h": 5, "w": 16, "x": 8, "y": 30 },
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "targets": [
        {
          "expr": "sum by(instance) (count_over_time({instance=~\"$instance\"} |~ \"(?i)(error|critical|exception|failed)\" [5m]))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 60,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["sum", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

    {
      "id": 14,
      "title": "System & Application Logs — Live Stream",
      "description": "Live stream of all log lines from the selected servers (including Laravel, system, and Docker).",
      "type": "logs",
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 35 },
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "targets": [
        {
          "expr": "{instance=~\"$instance\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },

    {
      "id": 60,
      "type": "row",
      "title": "🏨  Monitoring Hub — Self-Health & S3 Infrastructure",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 }
    },

    {
      "id": 15,
      "title": "Hub System Status",
      "description": "Is the Hub agent (Alloy/Node Exporter) communicating? GREEN = Hub is alive.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 50 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "up{instance=\"monitoring-hub\"}",
          "legendFormat": "Hub Health",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1    }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OFFLINE", "color": "red" }, "1": { "text": "ONLINE", "color": "green" } } }
          ]
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "orientation": "auto",
        "colorMode": "background",
        "justifyMode": "center"
      }
    },

    {
      "id": 18,
      "title": "LGTM Core Services Health",
      "description": "Are the internal LGTM containers up? Check if Loki and Mimir processes are healthy.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 18, "x": 6, "y": 50 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(up{job=\"loki\"}) OR on() vector(0)",
          "legendFormat": "LOKI",
          "refId": "A"
        },
        {
          "expr": "sum(up{job=\"mimir\"}) OR on() vector(0)",
          "legendFormat": "MIMIR",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1    }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["mean"] },
        "orientation": "horizontal",
        "colorMode": "background",
        "justifyMode": "center"
      }
    },

    {
      "id": 19,
      "title": "Hub Resource Load (CPU/RAM)",
      "description": "If these spike on the HUB, your monitoring might lag or drop data.",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 54 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\", instance=\"monitoring-hub\"}[5m])) * 100)",
          "legendFormat": "CPU %",
          "refId": "A"
        },
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes{instance=\"monitoring-hub\"} / node_memory_MemTotal_bytes{instance=\"monitoring-hub\"})) * 100",
          "legendFormat": "RAM %",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 70   },
              { "color": "red",    "value": 90   }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },

    {
      "id": 21,
      "title": "S3 Cloud Backend Status",
      "description": "S3 Storage is 'infinite' (no storage left limit), but we track operation health here.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 9, "x": 6, "y": 54 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(loki_storage_s3_request_duration_seconds_count{status_code=\"200\"}[5m])) / sum(rate(loki_storage_s3_request_duration_seconds_count[5m])) * 100",
          "legendFormat": "S3 Data Health %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null    },
              { "color": "yellow", "value": 99      },
              { "color": "green",  "value": 99.9    }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["mean"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },

    {
      "id": 22,
      "title": "Bucket Policy & Retention",
      "description": "Fixed configurations for your AWS S3 bucket persistence.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 9, "x": 15, "y": 54 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "vector(100)",
          "legendFormat": "Retention (Days)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name",
        "orientation": "horizontal",
        "justifyMode": "center"
      }
    },

    {
      "id": 15,
      "title": "Hub Root Partition — Free Space",
      "description": "Available space on the HUB EC2 script/log cache. Ensure this has breathing room (>10GB).",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 9, "x": 6, "y": 58 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "node_filesystem_avail_bytes{mountpoint=\"/\", instance=\"monitoring-hub\"}",
          "legendFormat": "Free Disk",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "min": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
